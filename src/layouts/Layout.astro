---
import Navbar from "../components/reusable/autogenNavbar.astro";
import BlobBG from "../components/reusable/blobBG.astro";

const navLinks = [
  { name: "Blog-md", href: "/blog", ariaLabel: "link to my blog" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="The personal site and blog of Jeffrey Mello"
    />
    <link rel="icon" type="image/svg+xml" href="../websiteicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>Jeffrey Mello</title>

    <meta charset="utf-8" />
    <title>
      The website one the one and only Jeffrey Mello (aka melloCoding)
    </title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
  </head>
  <body class="pt-5 h-[100%] md:pt-[10em] pb-20 md:pb-0">
    <!-- Display the blob background -->
    <BlobBG />
    <!-- Display the navbar -->
    <Navbar links={navLinks} />
    <slot />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
  }
</style>

<script is:inline>
  // Prevent FART (Flash of inAccurate coloR Theme)
  const theme = localStorage.getItem("theme") ?? "business";
  document.documentElement.setAttribute("data-theme", theme);
</script>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const desktopCheckbox = document.getElementById(
      "theme-checkbox",
    ) as HTMLInputElement;
    const mobileCheckbox = document.getElementById(
      "theme-checkbox-mobile",
    ) as HTMLInputElement;

    function updateCheckboxes(theme: string) {
      const isLight = theme === "light";
      if (desktopCheckbox) desktopCheckbox.checked = isLight;
      if (mobileCheckbox) mobileCheckbox.checked = isLight;
      document.documentElement.setAttribute("data-theme", theme);
      localStorage.setItem("theme", theme);
    }

    // Set initial states
    const savedTheme = localStorage.getItem("theme") ?? "business";
    updateCheckboxes(savedTheme);

    // Add event listeners for both checkboxes
    desktopCheckbox?.addEventListener("change", () => {
      const theme = desktopCheckbox.checked ? "light" : "business";
      updateCheckboxes(theme);
    });

    mobileCheckbox?.addEventListener("change", () => {
      const theme = mobileCheckbox.checked ? "light" : "business";
      updateCheckboxes(theme);
    });
  });
</script>
